# ============================================
#  WHAT GOES TO GITHUB (tracked)
# ============================================
#
#  site/docs.json          — Mintlify config
#  site/style.css          — Elements design system
#  site/.mintignore         — Mintlify ignore rules
#  site/pages/*.mdx        — All Codex content pages
#  site/images/            — Mintlify logos, favicon
#  README.md               — Repo readme
#  CONTRIBUTING.md          — Contribution guide
#  LICENSE                 — License
#  .gitignore              — This file
#

# ============================================
#  LOCAL-ONLY FOLDERS (not pushed to GitHub)
# ============================================

# Project context for AI agents (internal, not the Codex)
CLAUDE.md

# Brand assets, guidelines, design files
Creatives/

# Video scripts, article drafts, non-site content
content/

# Cowork skill source files and plugin
skills/
meridian-codex.plugin

# Working docs, roadmap, decisions, prompts
_workspace/

# CI/CD workflows (infrastructure, not the text)
.github/

# Mintlify infrastructure (not Codex content)
site/snippets/
site/api-reference/
site/logo/

# ============================================
#  SYSTEM / EDITOR FILES
# ============================================

# macOS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.vscode/
.idea/

# Node (if running mintlify dev locally)
node_modules/
