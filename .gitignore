# ============================================
#  WHITELIST MODEL — everything is ignored
#  unless explicitly allowed below.
#
#  If it is not the published word of the
#  Meridian Codex, it does not belong here.
# ============================================

# Ignore everything by default
*

# ============================================
#  ALLOWED: The published Meridian Codex
# ============================================

# Repo infrastructure
!.gitignore
!README.md
!CONTRIBUTING.md
!LICENSE
!PRIVACY.md

# The Codex (core framework)
!codex/
!codex/*.mdx

# The Range Audit
!audit/
!audit/*.mdx

# The Governance Layer (specification, critique, amendment log, case records, disconfirmation, changelog)
!governance/
!governance/*.mdx

# The Workshop (categories + architecture pages + tool profiles)
# Two-level structure per workshop-category-pages-two-surface-architecture (2026-05-13):
#   workshop/[category-slug]/index.mdx        — entry-point category page
#   workshop/[category-slug]/architecture.mdx — Architecture page
#   workshop/[category-slug]/[tool-slug].mdx  — tool profile
!workshop/
!workshop/*/
!workshop/*/*.mdx
