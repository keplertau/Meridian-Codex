# ============================================
#  WHITELIST MODEL — everything is ignored
#  unless explicitly allowed below.
#
#  If it is not the published word of the
#  Meridian Codex, it does not belong here.
# ============================================

# Ignore everything by default
*

# ============================================
#  ALLOWED: The published Meridian Codex
# ============================================

# Repo infrastructure
!.gitignore
!README.md
!CONTRIBUTING.md
!LICENSE

# The Codex (core framework)
!codex/
!codex/*.mdx

# The Toolkit (deep dives)
!toolkit/
!toolkit/*.mdx

# The Meridian AI Standard
!ai-standard/
!ai-standard/*.mdx

# The Case Record
!cases/
!cases/*.mdx

# The Range Audit
!audit/
!audit/*.mdx
